# RPC endpoints for wagmi (optional — public fallbacks are used when unset)
NEXT_PUBLIC_SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_KEY
NEXT_PUBLIC_MAINNET_RPC=https://mainnet.infura.io/v3/YOUR_KEY

# WalletConnect Cloud project ID — only needed for the WalletConnect modal.
# Injected wallets (MetaMask, Rabby, etc.) work without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# The Zama relayer is reached through the SDK's built-in public endpoints
# (relayer.testnet.zama.org for Sepolia, relayer.mainnet.zama.org for Mainnet),
# so no relayer URL or API key is required.
